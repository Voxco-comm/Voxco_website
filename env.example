# Supabase Configuration (required)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Required for approve-signup API (admin approving signups sends email from server)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Production: base URL of your app (used for server-side email callbacks and "Sign in to the portal" links in emails)
# Set at least one so order/signup notification emails contain a working portal link (e.g. https://your-domain.com or http://localhost:3000 for local)
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Email Configuration (required for order/signup notifications)
# Gmail: enable 2-Step Verification, then create App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-character-app-password
EMAIL_FROM=your-email@gmail.com

# Optional: country requirements AI (one of these for /api/country-requirements)
# GROQ_API_KEY=your_groq_api_key
# HUGGINGFACE_API_KEY=your_huggingface_api_key

